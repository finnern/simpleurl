{
  "manifest_version": 3,
  "name": "SimpleURL",
  "version": "1.0.0",
  "description": "Automatically strips query parameters from URLs when copying or pasting",
  "permissions": ["clipboardWrite"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
